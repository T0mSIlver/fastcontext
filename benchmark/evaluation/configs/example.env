# Example environment config for mini-swe-agent + FastContext benchmark.
# Copy this file and fill in your API credentials.
#
# Main agent config (the SWE agent that solves issues)
# Uses litellm model names: https://docs.litellm.ai/docs/providers
# For Azure: use azure/<deployment-name> and set AZURE_API_KEY + AZURE_API_BASE
MAIN_MODEL=azure/deepprompt-gpt-5.4-2026-03-05-global
MAIN_TEMPERATURE=0.0
MAIN_DROP_PARAMS=true

# Main agent Azure credentials (used by litellm)
AZURE_API_KEY=your-main-agent-api-key-here
AZURE_API_BASE=https://your-endpoint.openai.azure.com/
AZURE_API_VERSION=2024-12-01-preview

# FastContext subagent config (the code search agent)
# These are passed as environment variables inside the Docker container.
# FastContext and main agent can use different models / API keys.
FASTCONTEXT_MODEL=deepprompt-gpt-5.4-2026-03-05-global
FASTCONTEXT_API_KEY=your-fastcontext-api-key-here
FASTCONTEXT_BASE_URL=https://your-endpoint.openai.azure.com/
FASTCONTEXT_API_TYPE=azure
FASTCONTEXT_API_VERSION=2024-12-01-preview
# FASTCONTEXT_REASONING_EFFORT=low
